<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["ApiMonitor.Web.styles.css"]" />
    <link href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" rel="stylesheet" />
    <link href="_content/Blazorise.Icons.FontAwesome/v6/css/all.min.css" rel="stylesheet">

    <link href="_content/Blazorise/blazorise.css?v=2.1.2.0" rel="stylesheet" />
    <link href="_content/Blazorise.Bootstrap5/blazorise.bootstrap5.css?v=2.1.2.0" rel="stylesheet" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <ThemeProvider Theme="@ApiMonitorTheme">
        <Routes />
        <ReconnectModal />
    </ThemeProvider>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    // Dark mode strategy: keep Blazorise semantics mapped to CSS tokens.
    // Switching [data-theme="dark"] updates visual values without reconfiguring the Theme.
    private static readonly Theme ApiMonitorTheme = new()
    {
        ColorOptions = new ThemeColorOptions
        {
            Primary = "#2563EB",
            Secondary = "#475569",
            Success = "#047857",
            Warning = "#B45309",
            Danger = "#B91C1C",
            Info = "#0284C7",
            Light = "#F1F5F9",
            Dark = "#0F172A",
            Link = "#2563EB",
        },
        BackgroundOptions = new ThemeBackgroundOptions
        {
            Primary = "#2563EB",
            Secondary = "#475569",
            Success = "#ECFDF5",
            Warning = "#FFFBEB",
            Danger = "#FEF2F2",
            Info = "#DBEAFE",
            Light = "#F1F5F9",
            Dark = "#0F172A",
        },
        TextColorOptions = new ThemeTextColorOptions
        {
            Primary = "#2563EB",
            Secondary = "#475569",
            Success = "#047857",
            Warning = "#B45309",
            Danger = "#B91C1C",
            Info = "#0284C7",
            Light = "#FFFFFF",
            Dark = "#0F172A",
        },
        BodyOptions = new ThemeBodyOptions
        {
            BackgroundColor = "#F8FAFC",
            TextColor = "#0F172A",
            FontOptions = new ThemeFontOptions
            {
                Family = "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
                Size = "1rem",
                Weight = "400",
            },
        },
        ButtonOptions = new ThemeButtonOptions
        {
            LargeBorderRadius = "10px",
            SmallBorderRadius = "6px",
        },
        InputOptions = new ThemeInputOptions
        {
            Color = "#2563EB",
            CheckColor = "#2563EB",
            SliderColor = "#2563EB",
        },
    };
}
