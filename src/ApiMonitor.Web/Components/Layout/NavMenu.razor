@using Microsoft.AspNetCore.Components.Routing

<nav class="am-nav" aria-label="Primary">
    <NavLink class="am-nav-link" href="dashboard" @onclick="NotifyNavigate">
        <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
        <span>Dashboard</span>
    </NavLink>

    <NavLink class="am-nav-link" href="apis" @onclick="NotifyNavigate">
        <i class="fa-solid fa-plug" aria-hidden="true"></i>
        <span>APIs</span>
    </NavLink>

    <NavLink class="am-nav-link" href="logs" @onclick="NotifyNavigate">
        <i class="fa-solid fa-scroll" aria-hidden="true"></i>
        <span>Logs</span>
    </NavLink>

    <NavLink class="am-nav-link" href="alerts" @onclick="NotifyNavigate">
        <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
        <span>Alerts</span>
    </NavLink>

    <NavLink class="am-nav-link" href="settings" @onclick="NotifyNavigate">
        <i class="fa-solid fa-gear" aria-hidden="true"></i>
        <span>Settings</span>
    </NavLink>
</nav>

@code {
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private Task NotifyNavigate()
        => OnNavigate.InvokeAsync();
}
